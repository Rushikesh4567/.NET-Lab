@page
@model LibraryProject.Pages.Books.DeleteModel
@{
    ViewData["Title"] = "Delete Book";
}

<div class="container py-5">
    <div class="card border-danger mx-auto shadow" style="max-width: 500px;">
        <div class="card-header bg-danger text-white text-center">
            <h4 class="mb-0">Confirm Deletion</h4>
        </div>
        <div class="card-body text-center py-4">
            <p class="mt-3 fs-5">Are you sure you want to remove this book from the library?</p>
            <p class="text-muted small mb-4">Book ID: <strong>@Model.Id</strong> &mdash; This action cannot be undone.</p>

            <form method="post">
                <input type="hidden" asp-for="Id" />
                <button type="submit" class="btn btn-danger px-5 me-2">Yes, Delete</button>
                <a href="/Books/Index" class="btn btn-secondary px-4">Cancel</a>
            </form>
        </div>
    </div>
</div>
